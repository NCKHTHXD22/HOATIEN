# ============================================================
# BACKEND ENV - Xã Hoa Tiến Hybrid DB
# Sao chép file này thành .env và điền thông tin thực
# ============================================================

# --- SERVER ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL (Neon) ---
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# --- MongoDB (Atlas) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGODB_DB_NAME=hoa_tien

# --- JWT ---
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- Zalo OA ---
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret
ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token
ZALO_OA_REFRESH_TOKEN=your_zalo_oa_refresh_token
ZALO_WEBHOOK_SECRET=your_zalo_webhook_secret
# Lấy từ trang Xác thực domain Zalo Developers (meta tag content)
ZALO_VERIFIER_CODE=your_zalo_verifier_code

# --- Cloudinary (lưu hình ảnh / video) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Upstash Redis (lưu token Zalo OA) ---
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# --- Email (Gmail SMTP) ---
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# --- SMS (ESMS.vn) ---
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=HOATIEN

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
